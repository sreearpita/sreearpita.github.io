---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  certifications,
  education,
  experience,
  metrics,
  profile,
  projects,
  skills,
} from '../data/portfolio';

const featuredProjects = projects.filter((project) => project.featured);
const archiveProjects = projects.filter((project) => !project.featured);
---

<BaseLayout>
  <header class="site-header" data-site-header>
    <a class="brand" href="#top" aria-label="Sree Arpita Patra home">
      <span>SAP</span>
    </a>
    <nav class="site-nav" id="site-menu" aria-label="Primary navigation">
      <a href="#work">Work</a>
      <a href="#experience">Experience</a>
      <a href="#skills">Skills</a>
      <a href="/resume">Resume</a>
      <a href="#contact">Contact</a>
    </nav>
    <button class="menu-toggle" type="button" aria-controls="site-menu" aria-expanded="false" data-menu-toggle>
      <span class="sr-only">Toggle navigation</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </header>

  <main id="top">
    <section class="hero section-shell">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow">Software Engineer - Singapore</p>
        <h1>{profile.name}</h1>
        <p class="hero-role">{profile.title}</p>
        <p class="hero-summary">{profile.positioning}</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button button-primary" href="#work">
            View selected work
            <span aria-hidden="true">-&gt;</span>
          </a>
          <a class="button button-secondary" href={`mailto:${profile.email}`}>
            Email me
            <span aria-hidden="true">-&gt;</span>
          </a>
          <a class="text-link" href="/resume">Open resume page</a>
        </div>
      </div>

      <div class="hero-visual" data-hero-visual data-reveal aria-label="Animated system architecture preview" role="img">
        <canvas data-architecture-canvas aria-hidden="true"></canvas>
        <div class="visual-fallback" aria-hidden="true">
          <span class="fallback-node node-a"></span>
          <span class="fallback-node node-b"></span>
          <span class="fallback-node node-c"></span>
          <span class="fallback-line line-a"></span>
          <span class="fallback-line line-b"></span>
        </div>
        <span class="system-label label-frontend">Frontend</span>
        <span class="system-label label-api">API</span>
        <span class="system-label label-services">Services</span>
        <span class="system-label label-data">Data</span>
      </div>
    </section>

    <section class="metrics-band" aria-label="Portfolio highlights">
      {metrics.map((metric) => (
        <article class="metric-card" data-reveal>
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
          <p>{metric.detail}</p>
        </article>
      ))}
    </section>

    <section class="section-shell section-split" id="work">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Selected work</p>
        <h2>Projects framed around role, systems, and outcome.</h2>
        <p>
          End-to-end builds across ordering, AI, health, booking, and commerce, with attention to
          user journeys, service boundaries, data flow, and delivery.
        </p>
      </div>

      <div class="featured-grid">
        {featuredProjects.map((project, index) => (
          <article class={`project-card project-card-${index + 1}`} data-reveal>
            <div class="project-card-top">
              <p class="project-period">{project.period}</p>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
            </div>
            <div class="project-detail">
              <span>Problem</span>
              <p>{project.problem}</p>
            </div>
            <div class="project-detail">
              <span>Role</span>
              <p>{project.role}</p>
            </div>
            {project.highlights && (
              <ul class="project-highlights">
                {project.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            )}
            <div class="stack-list" aria-label={`${project.title} technology stack`}>
              {project.stack.map((item) => <span>{item}</span>)}
            </div>
            <div class="project-links">
              {project.links.map((link) => (
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                  <span aria-hidden="true">-&gt;</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="archive-panel" data-reveal>
        <div>
          <p class="eyebrow">Project archive</p>
          <h3>Additional builds</h3>
        </div>
        <div class="archive-list">
          {archiveProjects.map((project) => (
            <article>
              <div>
                <p>{project.period}</p>
                <h4>{project.title}</h4>
                <span>{project.stack.join(' / ')}</span>
              </div>
              <a href={project.links[0].href} target="_blank" rel="noopener noreferrer">
                Code
                <span aria-hidden="true">-&gt;</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="experience-section section-shell" id="experience">
      <div class="section-heading compact" data-reveal>
        <p class="eyebrow">Experience</p>
        <h2>Enterprise delivery across telecom, fintech, and commerce.</h2>
      </div>
      <div class="experience-rail">
        {experience.map((item) => (
          <article class="experience-item" data-reveal>
            <div class="experience-meta">
              <span>{item.period}</span>
              <strong>{item.company}</strong>
              <small>{item.location}</small>
            </div>
            <div class="experience-body">
              <h3>{item.role}</h3>
              <p>{item.summary}</p>
              <ul>
                {item.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="skills-section section-shell" id="skills">
      <div class="section-heading" data-reveal>
        <p class="eyebrow">Capability map</p>
        <h2>Skill matrix backed by shipped surfaces.</h2>
        <p>
          Practical engineering range across product UI, service design, data integration, cloud-aware
          delivery, security practices, and testable system boundaries.
        </p>
      </div>
      <div class="skills-grid">
        {skills.map((group) => (
          <article class="skill-card" data-reveal>
            <h3>{group.label}</h3>
            <p>{group.proof}</p>
            <div class="stack-list">
              {group.tools.map((tool) => <span>{tool}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="education-section section-shell">
      <div class="section-heading compact" data-reveal>
        <p class="eyebrow">Education and training</p>
        <h2>Computer science foundation with software engineering training.</h2>
      </div>
      <div class="education-grid">
        {education.map((item) => (
          <article class="education-card" data-reveal>
            <p>{item.period}</p>
            <h3>{item.qualification}</h3>
            <span>{item.institution}</span>
          </article>
        ))}
        <article class="education-card" data-reveal>
          <p>Certifications</p>
          <h3>Professional trainings</h3>
          <ul>
            {certifications.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="contact-section section-shell" id="contact">
      <div class="contact-panel" data-reveal>
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Open to software engineering and platform roles.</h2>
          <p>
            Based in {profile.location}, with experience spanning enterprise platforms, product
            workflows, modernization work, and full-cycle delivery.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button button-primary" href={`mailto:${profile.email}`}>Email Sree</a>
          <button class="button button-secondary" type="button" data-copy-email data-email={profile.email}>
            Copy email
          </button>
          <a class="text-link" href={profile.linkedIn} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a class="text-link" href={profile.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          <p class="copy-status" data-copy-status role="status" aria-live="polite"></p>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p>&copy; 2026 {profile.name}. Built with Astro.</p>
    <a href="#top">Back to top</a>
  </footer>
</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import {
    BoxGeometry,
    BufferGeometry,
    EdgesGeometry,
    Group,
    Line,
    LineBasicMaterial,
    LineSegments,
    Mesh,
    MeshBasicMaterial,
    PerspectiveCamera,
    Scene,
    TorusGeometry,
    Vector3,
    WebGLRenderer,
  } from 'three';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const menuToggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('#site-menu');

  if (menuToggle && menu) {
    menuToggle.addEventListener('click', () => {
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
      menu.dataset.open = String(!isOpen);
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menuToggle.setAttribute('aria-expanded', 'false');
        menu.dataset.open = 'false';
      });
    });
  }

  const revealItems = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));

  if (reducedMotion) {
    revealItems.forEach((item) => item.classList.add('is-visible'));
  } else {
    gsap.set(revealItems, { opacity: 0, y: 26 });
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          gsap.to(entry.target, {
            opacity: 1,
            y: 0,
            duration: 0.75,
            ease: 'power3.out',
          });
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.18 }
    );
    revealItems.forEach((item) => observer.observe(item));
  }

  const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-email]');
  const copyStatus = document.querySelector<HTMLElement>('[data-copy-status]');

  copyButton?.addEventListener('click', async () => {
    const email = copyButton.dataset.email;
    if (!email) return;

    try {
      await navigator.clipboard.writeText(email);
      if (copyStatus) copyStatus.textContent = 'Email copied.';
    } catch {
      if (copyStatus) copyStatus.textContent = email;
    }
  });

  function initArchitectureScene() {
    const visual = document.querySelector<HTMLElement>('[data-hero-visual]');
    const canvas = document.querySelector<HTMLCanvasElement>('[data-architecture-canvas]');
    if (!visual || !canvas) return;

    try {
      const renderer = new WebGLRenderer({
        canvas,
        alpha: true,
        antialias: true,
        preserveDrawingBuffer: true,
      });
      const scene = new Scene();
      const camera = new PerspectiveCamera(42, 1, 0.1, 100);
      const group = new Group();
      const palette = [0x37e6a6, 0xff6b4a, 0x64d2ff, 0xf2cf66];
      const positions = [
        new Vector3(-2.15, 0.9, 0),
        new Vector3(-0.65, -0.15, 0.2),
        new Vector3(0.95, 0.55, -0.15),
        new Vector3(2.05, -0.85, 0.15),
      ];

      scene.add(group);
      camera.position.set(0, 0, 6.4);

      const cubeGeometry = new BoxGeometry(0.42, 0.42, 0.42);
      const edgeGeometry = new BoxGeometry(0.48, 0.48, 0.48);

      positions.forEach((position, index) => {
        const node = new Mesh(
          cubeGeometry,
          new MeshBasicMaterial({ color: palette[index], transparent: true, opacity: 0.92 })
        );
        const wire = new LineSegments(
          new EdgesGeometry(edgeGeometry),
          new LineBasicMaterial({ color: 0xf7f1df, transparent: true, opacity: 0.55 })
        );
        node.position.copy(position);
        wire.position.copy(position);
        node.rotation.set(index * 0.3, index * 0.18, index * 0.22);
        wire.rotation.copy(node.rotation);
        group.add(node, wire);
      });

      for (let index = 0; index < positions.length - 1; index += 1) {
        const lineGeometry = new BufferGeometry().setFromPoints([
          positions[index],
          positions[index + 1],
        ]);
        const line = new Line(
          lineGeometry,
          new LineBasicMaterial({ color: 0xf7f1df, transparent: true, opacity: 0.28 })
        );
        group.add(line);
      }

      const ring = new LineSegments(
        new EdgesGeometry(new TorusGeometry(1.95, 0.035, 8, 80)),
        new LineBasicMaterial({ color: 0x64d2ff, transparent: true, opacity: 0.22 })
      );
      ring.rotation.set(0.95, 0.2, -0.4);
      group.add(ring);

      const resize = () => {
        const rect = visual.getBoundingClientRect();
        const width = Math.max(320, Math.floor(rect.width));
        const height = Math.max(320, Math.floor(rect.height));
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(width, height, false);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();
        renderer.render(scene, camera);
      };

      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(visual);
      resize();
      visual.classList.add('is-canvas-ready');

      if (reducedMotion) {
        renderer.render(scene, camera);
        return;
      }

      gsap.to(group.rotation, {
        y: Math.PI * 2,
        z: Math.PI * 0.2,
        duration: 28,
        repeat: -1,
        ease: 'none',
      });

      const animate = () => {
        renderer.render(scene, camera);
        window.requestAnimationFrame(animate);
      };

      animate();
    } catch {
      visual.classList.remove('is-canvas-ready');
    }
  }

  initArchitectureScene();
</script>
